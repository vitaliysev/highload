@startuml C4_Context

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title C4 Level 1 — System Context: Маркетплейс объявлений

Person(buyer_seller, "Покупатель / Продавец", "Физическое лицо. Создаёт объявления, ищет товары, оплачивает продвижение через браузер или мобильное приложение.")
Person(moderator, "Модератор", "Сотрудник компании. Проверяет объявления, не прошедшие автоматическую модерацию.")

System(marketplace, "Маркетплейс объявлений", "Платформа для публикации и поиска объявлений. Обеспечивает создание объявлений, полнотекстовый поиск, модерацию контента и платное продвижение.")

System_Ext(payment_gateway, "Платёжный шлюз\n(СПБ / Эквайринг)", "Обрабатывает платежи за продвижение объявлений. Уведомляет систему о результате оплаты через webhook.")
System_Ext(ml_moderation, "ML Moderation API", "Классифицирует текст и изображения объявлений. Возвращает решение: одобрено / на ручную проверку / отклонено.")
System_Ext(cdn, "CDN\n(Yandex CDN)", "Раздаёт фотографии объявлений конечным пользователям с минимальной задержкой из ближайшей точки присутствия.")
System_Ext(sms_push, "SMS / Push провайдер", "Отправляет уведомления пользователям о результатах модерации и статусах платежей.")
System_Ext(oauth, "OAuth\n(VK / Яндекс)", "Обеспечивает внешнюю аутентификацию пользователей через социальные сети.")

Rel(buyer_seller, marketplace, "Создаёт объявления, ищет товары, оплачивает продвижение", "HTTPS")
Rel(moderator, marketplace, "Проверяет и модерирует объявления", "HTTPS")

Rel(marketplace, payment_gateway, "Инициирует платёж, получает webhook с результатом", "HTTPS")
Rel(marketplace, ml_moderation, "Отправляет текст и фото для автоматической проверки", "HTTPS")
Rel(marketplace, cdn, "Публикует фотографии, CDN раздаёт их пользователям", "S3 API")
Rel(marketplace, sms_push, "Отправляет задачи на доставку уведомлений", "HTTPS / AMQP")
Rel(marketplace, oauth, "Аутентифицирует пользователей через внешние провайдеры", "OAuth 2.0")

@enduml
